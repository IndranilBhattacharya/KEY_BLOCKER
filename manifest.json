{
  "name": "KEY BLOCKER",
  "description": "Blocks access to websites (as per keywords user specifies) to improve productivity.",
  "version": "2.0",
  "author": "Indranil Bhattacharya",
  "manifest_version": 3,
  "action": {
    "default_popup": "index.html",
    "default_icon": "assets/logo/logo128.png"
  },
  "icons": {
    "16": "assets/logo/logo16.png",
    "24": "assets/logo/logo24.png",
    "32": "assets/logo/logo32.png",
    "64": "assets/logo/logo64.png",
    "128": "assets/logo/logo128.png",
    "256": "assets/logo/logo256.png",
    "512": "assets/logo/logo512.png"
  },
  "permissions": ["storage", "tabs", "unlimitedStorage"],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
